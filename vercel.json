{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.orostone.sk" }],
      "destination": "https://orostone.sk/$1",
      "permanent": true
    },
    {
      "source": "/((?!favicon.*|apple-touch-icon.*|robots\\.txt).*)",
      "has": [{ "type": "host", "value": "eshop.orostone.sk" }],
      "destination": "https://orostone.sk/$1",
      "permanent": true
    },
    { "source": "/kolekcie/:path*", "destination": "/kategoria/sintered-stone", "permanent": true },
    { "source": "/kolekcie", "destination": "/kategoria/sintered-stone", "permanent": true },
    { "source": "/vsetky-produkty", "destination": "/kategoria/sintered-stone", "permanent": true },
    { "source": "/shop", "destination": "/", "permanent": true },
    { "source": "/online-kalkulacka", "destination": "/vzorky", "permanent": true },
    { "source": "/vizualizator", "destination": "/vzorky", "permanent": true },
    { "source": "/key-facts", "destination": "/sinterovany-kamen", "permanent": true },
    { "source": "/o-kameni", "destination": "/sinterovany-kamen", "permanent": true },
    { "source": "/onas", "destination": "/kontakt", "permanent": true },
    { "source": "/contact", "destination": "/kontakt", "permanent": true },
    { "source": "/kamen/bulgari---calacatta-viola", "destination": "/produkt/calacatta-top", "permanent": true },
    { "source": "/kamen/patagonia", "destination": "/produkt/roman-travertine", "permanent": true },
    { "source": "/kamen/pure-black", "destination": "/produkt/nero-margiua", "permanent": true },
    { "source": "/kamen/blue-onyx", "destination": "/produkt/nero-margiua", "permanent": true },
    { "source": "/kamen/dolomit", "destination": "/produkt/appennino", "permanent": true },
    { "source": "/kamen/panda-white", "destination": "/produkt/super-white-extra", "permanent": true },
    { "source": "/kamen/calacatta-bianco", "destination": "/produkt/calacatta-top", "permanent": true },
    { "source": "/kamen/calacatta-gold", "destination": "/produkt/givenchy-gold", "permanent": true },
    { "source": "/kamen/:slug*", "destination": "/kategoria/sintered-stone", "permanent": true },
    { "source": "/blog/technicky-kamen-pracovna-doska", "destination": "/blog/technicky-kamen-cena-pracovna-doska", "permanent": true },
    { "source": "/post/:slug*", "destination": "/blog", "permanent": true },
    { "source": "/blank", "destination": "/", "permanent": true },
    { "source": "/login", "destination": "https://shopify.com/101386420570/account", "permanent": false },
    { "source": "/register", "destination": "https://shopify.com/101386420570/account", "permanent": false },
    { "source": "/ucet", "destination": "https://shopify.com/101386420570/account", "permanent": false },
    { "source": "/objednavky", "destination": "https://shopify.com/101386420570/account", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "has": [{ "type": "host", "value": "eshop.orostone.sk" }],
      "destination": "/robots-noindex.txt"
    },
    { "source": "/sitemap.xml", "destination": "/sitemap-eshop.xml" },
    { "source": "/sitemap-eshop.xml", "destination": "/sitemap-eshop.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/pages-sitemap.xml", "destination": "/sitemap-eshop.xml" },
    { "source": "/sitemap-index.xml", "destination": "/sitemap-eshop.xml" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    {
      "source": "/produkt/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|WhatsApp|TelegramBot|Discordbot|Pinterestbot|vkShare|Viber|Skype|redditbot|Applebot).*"
        }
      ],
      "destination": "/api/product-meta?slug=:slug"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/(.*)",
      "missing": [{ "type": "host", "value": "orostone.sk" }],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
