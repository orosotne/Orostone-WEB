# ============================================
# Orostone 5 — Environment Variables
# ============================================
# Skopírujte tento súbor do .env a vyplňte hodnoty
# cp .env.example .env
# ============================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Shopify Storefront API ---
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-access-token
# Farebné filtre (mega menu, /kategoria/.../biele …):
# Shopify category metafield "Color" (namespace shopify, key color) alebo color-pattern —
# hodnoty typu white / grey / beige / black sa v kóde mapujú na biele / sede / bezove / cierne.
# Voliteľný override: custom.color_category = biele|sede|bezove|cierne.
# Metafield definície musia mať prístup pre Storefront API (Storefront access / PUBLIC_READ).
#
# Offline fallback (Shop.tsx, výpadok API, dev bez .env):
#   npm run sync:shop-fallback
# Zapíše aktuálny katalóg do data/shop-products-fallback.json — commitni do gitu.
# Voliteľne: SHOPIFY_FALLBACK_PRODUCT_LIMIT=250 (max 250 na jeden request).

# --- Gemini API (vizualizér) ---
GEMINI_API_KEY=your-gemini-api-key
