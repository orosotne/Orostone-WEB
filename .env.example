# ============================================
# Orostone 5 — Environment Variables
# ============================================
# Skopírujte tento súbor do .env a vyplňte hodnoty
# cp .env.example .env
# ============================================

# Verejný pôvod stránky (absolútne URL pre Open Graph / Twitter náhľady pri SPA navigácii).
# Lokálne nechaj prázdne — použije sa https://www.orostone.sk
# VITE_PUBLIC_SITE_URL=https://www.orostone.sk

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Shopify Storefront API (povinné pre košík a platby cez Shopify Checkout) ---
# Produkcia: doména a token z ŽIVÉHO obchodu (Settings → Apps → Develop apps → Storefront API).
# Bez týchto premenných isShopifyConfigured() = false — košík/checkout voči Shopify nefungujú.
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-access-token
# Farebné filtre (mega menu, /kategoria/.../biele …):
# Shopify category metafield "Color" (namespace shopify, key color) alebo color-pattern —
# hodnoty typu white / grey / beige / black sa v kóde mapujú na biele / sede / bezove / cierne.
# Voliteľný override: custom.color_category = biele|sede|bezove|cierne.
# Metafield definície musia mať prístup pre Storefront API (Storefront access / PUBLIC_READ).
#
# Offline fallback (Shop.tsx, výpadok API, dev bez .env):
#   npm run sync:shop-fallback
# Zapíše aktuálny katalóg do data/shop-products-fallback.json — commitni do gitu.
# Voliteľne: SHOPIFY_FALLBACK_PRODUCT_LIMIT=250 (max 250 na jeden request).

# --- Meta Pixel (Facebook / Instagram remarketing) ---
# Voliteľné. Pixel sa načíta len pri súhlase s marketing cookies.
# VITE_META_PIXEL_ID=1234567890123456

# --- Cloudflare Turnstile (bot ochrana formulárov) ---
VITE_TURNSTILE_SITEKEY=your-turnstile-sitekey

# --- Gemini API (vizualizér) ---
GEMINI_API_KEY=your-gemini-api-key
